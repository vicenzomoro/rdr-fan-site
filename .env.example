# Configurações do Supabase (Obrigatório para Login/Comentários)
SUPABASE_URL=https://sua-url-do-supabase.supabase.co
SUPABASE_KEY=sua-chave-anon-do-supabase

# Chave Mestra do Admin (Obrigatório para o Painel do Xerife)
DEV_MASTER_KEY=sua-senha-mestra-aqui

# Inteligência Artificial (Opcional - Para o Chat do Dutch)
GEN_API_KEY=sua-chave-do-google-gemini
GEN_MODEL=gemini-1.5-flash

# Segurança de Mods (Opcional - VirusTotal)
VT_API_KEY=sua-chave-virustotal-aqui

# Configurações do Servidor
PORT=3000
NODE_ENV=production
