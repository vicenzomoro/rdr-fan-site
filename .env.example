# Copy this file to .env and fill in real values
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_KEY=your-anon-or-service-key
VT_API_KEY=your-virustotal-api-key
# generative API key for Gemini or OpenAI (prefix sk- identifies OpenAI)
GEN_API_KEY=your-generative-api-key
# model name for provider (Gemini or OpenAI)
GEN_MODEL=gemini-3v
DEV_MASTER_KEY=a-very-secret-admin-token
PORT=3000
